rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'sovereigntyLevel', 'updatedAt']);
      
      function isValidUser(data) {
        return data.uid == request.auth.uid &&
               data.updatedAt == request.time &&
               (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
               (data.sovereigntyLevel == null || (data.sovereigntyLevel is number && data.sovereigntyLevel >= 0 && data.sovereigntyLevel <= 100));
      }
    }

    // 2. Demands (Public Read, Authenticated Write)
    match /demands/{demandId} {
      allow list: if true; // Public view of demands
      allow get: if true;
      allow create: if isSignedIn() && isValidDemand(request.resource.data);
      
      function isValidDemand(data) {
        return data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
               data.createdAt == request.time;
      }
    }

    // 3. Crisis Reports (Owner Write/Read)
    match /crisis_reports/{reportId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidCrisis(request.resource.data);
      
      function isValidCrisis(data) {
        return data.type in ['crisis', 'safe_passage'] &&
               data.details is string && data.details.size() <= 2000 &&
               data.createdAt == request.time;
      }
    }

    // 4. Peer Chat (Authenticated List/Write)
    match /peer_chat/{messageId} {
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(request.resource.data);
      
      function isValidMessage(data) {
        return data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
               data.createdAt == request.time;
      }
    }
  }
}
